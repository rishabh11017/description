<?xml version="1.0"?>
<robot name="crazyflie">

  <!-- ===================================================== -->
  <!-- MATERIALS -->
  <!-- ===================================================== -->

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>

  <!-- ===================================================== -->
  <!-- BASE LINK -->
  <!-- ===================================================== -->

  <link name="base_link">

    <!-- ================= VISUAL ================= -->

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="package://crazyflie_description/meshes/base.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>

      <material name="black"/>
    </visual>

    <!-- ================= COLLISION ================= -->
    <!-- Approximate lightweight collision body -->

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <box size="0.095 0.095 0.02"/>
      </geometry>
    </collision>

    <!-- ================= INERTIAL ================= -->
    <!-- Converted from SolidWorks -->
    <!-- Values assumed transformed to ROS frame -->

    <inertial>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <!-- Crazyflie mass -->
      <mass value="0.026"/>

  <inertia
    ixx="1.114927e-05"
    ixy="4.825e-08"
    ixz="2.47e-09"
    iyy="1.131043e-05"
    iyz="7.65e-09"
    izz="2.155048e-05"/>
</inertial>

  </link>


  <!-- ===================================================== -->
  <!-- FRONT LEFT MOTOR : CCW -->
  <!-- ===================================================== -->

  <link name="propeller_ccw_1">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="package://crazyflie_description/meshes/propeller_ccw.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>

      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.023" length="0.004"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.0005"/>

      <inertia
        ixx="3e-7"
        ixy="0"
        ixz="0"
        iyy="4e-7"
        iyz="0"
        izz="7e-7"/>
    </inertial>

  </link>

  <joint name="joint_propeller_ccw_1" type="continuous">

    <parent link="base_link"/>
    <child link="propeller_ccw_1"/>

    <origin xyz="0.0316 0.0316 -0.0113"
            rpy="0 0 0"/>

    <axis xyz="0 0 1"/>

  </joint>


  <!-- ===================================================== -->
  <!-- FRONT RIGHT MOTOR : CW -->
  <!-- ===================================================== -->

  <link name="propeller_cw_2">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="package://crazyflie_description/meshes/propeller_cw.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>

      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.023" length="0.004"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.0005"/>

      <inertia
        ixx="3e-7"
        ixy="0"
        ixz="0"
        iyy="4e-7"
        iyz="0"
        izz="7e-7"/>
    </inertial>

  </link>

  <joint name="joint_propeller_cw_2" type="continuous">

    <parent link="base_link"/>
    <child link="propeller_cw_2"/>

    <origin xyz="0.0316 -0.0316 -0.0113"
            rpy="0 0 0"/>

    <axis xyz="0 0 -1"/>

  </joint>


  <!-- ===================================================== -->
  <!-- REAR RIGHT MOTOR : CCW -->
  <!-- ===================================================== -->

  <link name="propeller_ccw_3">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="package://crazyflie_description/meshes/propeller_ccw.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>

      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.023" length="0.004"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.0005"/>

      <inertia
        ixx="3e-7"
        ixy="0"
        ixz="0"
        iyy="4e-7"
        iyz="0"
        izz="7e-7"/>
    </inertial>

  </link>

  <joint name="joint_propeller_ccw_3" type="continuous">

    <parent link="base_link"/>
    <child link="propeller_ccw_3"/>

    <origin xyz="-0.0316 -0.0316 -0.0113"
            rpy="0 0 0"/>

    <axis xyz="0 0 1"/>

  </joint>


  <!-- ===================================================== -->
  <!-- REAR LEFT MOTOR : CW -->
  <!-- ===================================================== -->

  <link name="propeller_cw_4">

   <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="package://crazyflie_description/meshes/propeller_cw.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>

      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.023" length="0.004"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.0005"/>

      <inertia
        ixx="3e-7"
        ixy="0"
        ixz="0"
        iyy="4e-7"
        iyz="0"
        izz="7e-7"/>
    </inertial>

  </link>


  <joint name="joint_propeller_cw_4" type="continuous">

    <parent link="base_link"/>
    <child link="propeller_cw_4"/>

    <origin xyz="-0.0316 0.0316 -0.0113"
            rpy="0 0 0"/>

    <axis xyz="0 0 -1"/>

  </joint>

</robot>
